{
  "id": "cluckin-chuck-api",
  "remote_path": "wp-content/plugins/cluckin-chuck-api",
  "changelog_target": "docs/CHANGELOG.md",
  "extensions": {
    "wordpress": {}
  },
  "version_targets": [
    {
      "file": "cluckin-chuck-api.php",
      "pattern": "(?m)^\\s*\\*?\\s*Version:\\s*([0-9.]+)"
    },
    {
      "file": "cluckin-chuck-api.php",
      "pattern": "CLUCKIN_CHUCK_API_VERSION',\\s*'([0-9.]+)'"
    }
  ]
}
