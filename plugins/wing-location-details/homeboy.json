{
  "auto_cleanup": false,
  "changelog_target": "CHANGELOG.md",
  "extensions": {
    "wordpress": {}
  },
  "id": "wing-location-details",
  "remote_path": "wp-content/plugins/wing-location-details",
  "version_targets": [
    {
      "file": "wing-location-details.php",
      "pattern": "Version:\\s*([0-9.]+)"
    },
    {
      "file": "wing-location-details.php",
      "pattern": "WING_LOCATION_DETAILS_VERSION',\\s*'([0-9.]+)'"
    }
  ]
}